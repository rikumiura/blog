{
  "name": "@my-blog/db",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate:local": "wrangler d1 migrations apply my-blog-db --local",
    "migrate:remote": "wrangler d1 migrations apply my-blog-db --remote",
    "studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:generate": "node seeds/seed.ts",
    "seed:local": "$npm_execpath run seed:generate && wrangler d1 execute my-blog-db --local --file=./seeds/seed.sql"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.31.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.17.0"
  }
}
